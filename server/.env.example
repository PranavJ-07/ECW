# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/ethicraft

# ─── JWT (used in auth module — define now, wire later) ───
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary (used in uploads module — wire later) ─────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email / Nodemailer (used in auth module — wire later)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=EthiCraft <noreply@ethicraft.com>

# ─── Frontend (CORS) ──────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=debug
